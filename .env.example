# Copy this file to .env and fill in your real values.
# .env is gitignored and will never be committed to the repository.

# ---------------------------------------------------------------------------
# AI provider — Ollama (local, free, unlimited) is recommended
# ---------------------------------------------------------------------------
AI_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434/v1   # default — change only if needed

# Other providers (comment/uncomment as needed):
# AI_PROVIDER=groq
# GROQ_API_KEY=your_groq_api_key_here

# AI_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here

# AI_PROVIDER=claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------------------------------------------------------
# USTA TennisLink credentials
# ---------------------------------------------------------------------------
USTA_USERNAME=your_usta_email@example.com
USTA_PASSWORD=your_usta_password_here

# ---------------------------------------------------------------------------
# Match format
# ---------------------------------------------------------------------------
SINGLES_COURTS=2
SCORING_FORMAT=2 sets (tiebreak at 6-6 in each set); if sets are split 1-1 a super tiebreak is played (first to 10 points, win by 2)

# ---------------------------------------------------------------------------
# Team configuration
#
# Single team — fill in the three MY_TEAM_* values below.
# Multiple teams — use the TEAM_COUNT / TEAM_N_* format instead (see README).
# IMPORTANT: MY_TEAM_URL and USTA_TEAM_URL must both point to the SAME team.
# ---------------------------------------------------------------------------
MY_TEAM_NAME=Your Team Name Here
MY_TEAM_URL=https://www.tennisrecord.com/adult/teamprofile.aspx?teamname=YourTeamName&year=2026&s=2
USTA_TEAM_URL=https://tennislink.usta.com/Leagues/Main/statsandstandings.aspx#&&s=YourTeamToken

# ---------------------------------------------------------------------------
# Multi-team example (uncomment and fill in to support more than one team)
# ---------------------------------------------------------------------------
# TEAM_COUNT=2
# ACTIVE_TEAM=1
#
# TEAM_1_NAME=Your First Team Name
# TEAM_1_URL=https://www.tennisrecord.com/adult/teamprofile.aspx?teamname=FirstTeam&year=2026&s=2
# TEAM_1_USTA_URL=https://tennislink.usta.com/Leagues/Main/statsandstandings.aspx#&&s=Token1
#
# TEAM_2_NAME=Your Second Team Name
# TEAM_2_URL=https://www.tennisrecord.com/adult/teamprofile.aspx?teamname=SecondTeam&year=2026&s=2
# TEAM_2_USTA_URL=https://tennislink.usta.com/Leagues/Main/statsandstandings.aspx#&&s=Token2
