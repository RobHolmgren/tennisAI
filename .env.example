# Copy this file to .env and fill in your real values.
# .env is gitignored and will never be committed to the repository.

# Groq API key — free tier at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# AI provider: "groq" (default) or "claude"
AI_PROVIDER=groq

# Only needed if AI_PROVIDER=claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# USTA TennisLink credentials
USTA_USERNAME=your_usta_email@example.com
USTA_PASSWORD=your_usta_password_here

# Match format — number of singles courts (1 or 2; doubles is always 3)
SINGLES_COURTS=2

# Scoring format — describes how each court match is played
SCORING_FORMAT=2 sets (tiebreak at 6-6 in each set); if sets are split 1-1 a super tiebreak is played (first to 10 points, win by 2)

# Your team URLs — stored in .env only (never committed to the repo)
# MY_TEAM_URL=  (add your tennisrecord.com team profile URL here)
# USTA_TEAM_URL= (add your tennislink.usta.com Stats & Standings URL here)
